# Copy this file to .env for local Docker development.
APP_ENV=development
PORT=7860
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/transit_engine
CORS_ALLOWED_ORIGINS=http://localhost:3000
DATA_REFRESH_SECRET=replace-me
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct
# Free OSM geocoders are called only by the backend and cached in-process.
GEOCODER_NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODER_PHOTON_URL=https://photon.komoot.io
GEOCODER_USER_AGENT=TransHub-Jabodetabek/0.1 (replace-with-contact@example.com)
# Optional backend-only key: Search, Reverse Geocode, Traffic Flow, and track refinement.
TOMTOM_API_KEY=
TOMTOM_ROUTING_URL=https://api.tomtom.com/routing/1
# Legacy traffic-only variable; TOMTOM_API_KEY takes precedence when both exist.
# Without either key the backend labels and uses a Jakarta time-of-day historical profile.
TOMTOM_TRAFFIC_API_KEY=
# Keep at 1 on memory-constrained/0.1 vCPU deployments.
ROUTING_MAX_CONCURRENCY=1
# Free OSM fallback. TomTom pedestrian routing is preferred when its key exists.
PEDESTRIAN_ROUTER_URL=https://valhalla1.openstreetmap.de
PEDESTRIAN_ROUTER_TIMEOUT_SECONDS=5
PEDESTRIAN_ROUTER_MAX_CONCURRENCY=2
