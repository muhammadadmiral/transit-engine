# Production FastAPI Cloud configuration. Set these as app environment variables.
APP_ENV=production
DATABASE_URL=postgresql+asyncpg://[USERNAME]:[YOUR-PASSWORD]@[YOUR-POOLER-HOST].pooler.supabase.com:5432/postgres
CORS_ALLOWED_ORIGINS=https://your-web.vercel.app
DATA_REFRESH_SECRET=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct
